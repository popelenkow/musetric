{
  "extends": "../../tsconfigs/tsconfig.base.json",
  "references": [
    { "path": "./tsconfig.es.json" },
    { "path": "./tsconfig.cross.json" },
    { "path": "./tsconfig.src.spectrogram.json" }
  ],
  "compilerOptions": {
    "lib": ["ES2024", "DOM"],
    "types": ["vite/client"]
  },
  "include": [
    "${configDir}/src/common/**/*",
    "${configDir}/src/decoder/**/*",
    "${configDir}/src/player/**/*",
