{
  "name": "@musetric/audio",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "monorepo": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./es": {
      "monorepo": "./src/index.es.ts",
      "types": "./dist/index.es.d.ts",
      "import": "./dist/index.es.js",
      "default": "./dist/index.es.js"
    },
    "./decoder": {
      "monorepo": "./src/decoder/index.ts",
      "types": "./dist/decoder/index.d.ts",
      "import": "./dist/decoder/index.js",
      "default": "./dist/decoder/index.js"
    },
    "./decoder/worker": {
      "monorepo": "./src/decoder/worker/index.worker.ts",
      "types": "./dist/decoder/worker/index.worker.d.ts",
      "import": "./dist/decoder/worker/index.worker.js",
      "default": "./dist/decoder/worker/index.worker.js"
    },
    "./player": {
      "monorepo": "./src/player/index.ts",
      "types": "./dist/player/index.d.ts",
      "import": "./dist/player/index.js",
      "default": "./dist/player/index.js"
    },
    "./player/worklet": {
      "monorepo": "./src/player/worklet/index.worklet.ts",
      "types": "./dist/player/worklet/index.worklet.d.ts",
      "import": "./dist/player/worklet/index.worklet.js",
      "default": "./dist/player/worklet/index.worklet.js"
    },
    "./recording": {
      "monorepo": "./src/recording/index.ts",
      "types": "./dist/recording/index.d.ts",
      "import": "./dist/recording/index.js",
      "default": "./dist/recording/index.js"
    },
    "./recording/worklet": {
      "monorepo": "./src/recording/worklet/index.worklet.ts",
      "types": "./dist/recording/worklet/index.worklet.d.ts",
      "import": "./dist/recording/worklet/index.worklet.js",
      "default": "./dist/recording/worklet/index.worklet.js"
    },
    "./spectrogram": {
      "monorepo": "./src/spectrogram/index.ts",
      "types": "./dist/spectrogram/index.d.ts",
      "import": "./dist/spectrogram/index.js",
      "default": "./dist/spectrogram/index.js"
    },
    "./spectrogram/worker": {
      "monorepo": "./src/spectrogram/worker/index.worker.ts",
      "types": "./dist/spectrogram/worker/index.worker.d.ts",
      "import": "./dist/spectrogram/worker/index.worker.js",
      "default": "./dist/spectrogram/worker/index.worker.js"
    },
    "./timeline": {
      "monorepo": "./src/timeline/index.ts",
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.js",
      "default": "./dist/timeline/index.js"
    },
    "./waveform": {
      "monorepo": "./src/waveform/index.ts",
      "types": "./dist/waveform/index.d.ts",
      "import": "./dist/waveform/index.js",
      "default": "./dist/waveform/index.js"
    },
    "./waveform/worker": {
      "monorepo": "./src/waveform/worker/index.worker.ts",
      "types": "./dist/waveform/worker/index.worker.d.ts",
      "import": "./dist/waveform/worker/index.worker.js",
      "default": "./dist/waveform/worker/index.worker.js"
    }
  },
  "scripts": {
    "postinstall": "node ./scripts/install.ts",
    "project:build": "cpx \"src/**/*.wgsl\" dist --clean && tsc --build",
    "check:ts": "tsc --build",
    "check:lint": "eslint . --cache",
    "fix:lint": "eslint . --fix --cache",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@alexanderolsen/libsamplerate-js": "2.1.2",
    "@musetric/resource-utils": "workspace:*",
    "mediabunny": "1.35.1",
    "signalsmith-stretch": "1.3.2"
  },
  "devDependencies": {
    "@alexanderolsen/libsamplerate-js": "catalog:",
    "@musetric/eslint-config": "workspace:*",
    "@musetric/resource-utils": "workspace:*",
    "@types/audioworklet": "catalog:",
    "@types/node": "catalog:",
    "@vitest/browser": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@webgpu/types": "catalog:",
    "cpx2": "catalog:",
    "eslint": "catalog:",
    "mediabunny": "catalog:",
    "playwright": "catalog:",
    "signalsmith-stretch": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
